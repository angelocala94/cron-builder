{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "cron-builder-registry",
  "homepage": "https://angelocala94.github.io/cron-builder/",
  "items": [
    {
      "name": "cron-builder",
      "type": "registry:block",
      "title": "Cron Builder",
      "description": "A cron expression builder for shadcn projects.",
      "registryDependencies": ["button", "popover"],
      "files": [
        {
          "path": "registry/new-york/components/cron-builder.tsx",
          "type": "registry:component"
        },
        {
          "path": "registry/new-york/lib/cron-builder/converter.ts",
          "type": "registry:lib"
        },
        {
          "path": "registry/new-york/lib/cron-builder/locale.ts",
          "type": "registry:lib"
        },
        {
          "path": "registry/new-york/lib/cron-builder/types.ts",
          "type": "registry:lib"
        }
      ],
      "docs": "Install this item in a shadcn project to get the cron builder plus its parser helpers. No sidecar stylesheet import is required."
    }
  ]
}
